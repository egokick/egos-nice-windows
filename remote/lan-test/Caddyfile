{
    admin off
}

# The only cleartext handler is Headscale's connectivity probe. Port 80 is not
# published by compose; all real client traffic uses internal-CA HTTPS on 443.
http://headscale.stayactive.test {
    @generate204 path /generate_204
    respond @generate204 204
    redir https://{host}{uri} permanent
}

http://meshcentral.stayactive.test {
    redir https://{host}{uri} permanent
}

http://remotehub.stayactive.test {
    redir https://{host}{uri} permanent
}

http://id.stayactive.test {
    redir https://{host}{uri} permanent
}

headscale.stayactive.test {
    tls internal

    # Headscale's REST API accepts a broadly privileged API key. Never expose
    # that surface to LAN clients: only the isolated EnrollmentBroker container
    # may reach it over Caddy's internally trusted HTTPS path.
    @enrollmentBrokerHeadscaleApi {
        path /api/v1/*
        remote_ip 172.30.60.16
    }
    handle @enrollmentBrokerHeadscaleApi {
        reverse_proxy headscale:8080
    }
    handle /api/v1/* {
        respond "Not found" 404
    }

    handle {
        reverse_proxy headscale:8080
    }
}

meshcentral.stayactive.test {
    tls internal
    reverse_proxy meshcentral:4430
}

remotehub.stayactive.test {
    tls internal

    # This is the only broker ingress. The broker is intentionally a separate
    # service from RemoteHub so the inventory API never receives a Headscale
    # administrative credential.
    @enrollmentTickets path /api/v1/enrollment-tickets /api/v1/enrollment-tickets/*
    handle @enrollmentTickets {
        reverse_proxy enrollmentbroker:5090
    }

    handle {
        reverse_proxy remotehub:5088
    }
}

id.stayactive.test {
    tls internal
    reverse_proxy keycloak:8080 {
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-Host {host}
        header_up X-Forwarded-Port 443
    }
}