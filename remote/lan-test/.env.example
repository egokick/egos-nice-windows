# Copy to .env only by scripts/Initialize-LanTest.ps1. Every image reference
# must be a digest after the script resolves and displays the selected image.
COMPOSE_PROJECT_NAME=stayactive-remotes-lan-test
# CADDY_BIND_ADDRESS is temporarily set to 127.0.0.1 during MeshCentral
# administrator bootstrap; final LAN operation binds both values to LAN_IP.
LAN_IP=192.168.1.168
CADDY_BIND_ADDRESS=192.168.1.168
STUN_BIND_ADDRESS=192.168.1.168
CONTROL_NETWORK_CIDR=172.30.60.0/24
CADDY_CONTROL_IP=172.30.60.10
HEADSCALE_CONTROL_IP=172.30.60.11
MESHCENTRAL_CONTROL_IP=172.30.60.12
REMOTEHUB_CONTROL_IP=172.30.60.13
KEYCLOAK_CONTROL_IP=172.30.60.14
POSTGRES_CONTROL_IP=172.30.60.15
# Bootstrap value only. Finalize-LanTest.ps1 replaces it with the Windows WSL
# virtual-interface address that Caddy may use for the controller route.
# The controller key is never an environment value or a Docker-mounted file.
WINDOWS_ENROLLMENT_CONTROLLER_IP=host.docker.internal

CADDY_IMAGE=__DIGEST_PIN_REQUIRED__
HEADSCALE_IMAGE=__DIGEST_PIN_REQUIRED__
MESHCENTRAL_IMAGE=__DIGEST_PIN_REQUIRED__
KEYCLOAK_IMAGE=__DIGEST_PIN_REQUIRED__
POSTGRES_IMAGE=__DIGEST_PIN_REQUIRED__
REMOTEHUB_SDK_IMAGE=__DIGEST_PIN_REQUIRED__
REMOTEHUB_RUNTIME_IMAGE=__DIGEST_PIN_REQUIRED__
REMOTEHUB_SOURCE_REVISION=__REVIEWED_COMMIT_REQUIRED__

POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=__GENERATED_LOCAL_SECRET__
KC_BOOTSTRAP_ADMIN_USERNAME=stayactive-bootstrap
KC_BOOTSTRAP_ADMIN_PASSWORD=__GENERATED_LOCAL_SECRET__