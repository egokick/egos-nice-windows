# Copy to remote/.env and fill every value before running Docker Compose.
# Do not put passwords, API keys, OIDC client secrets, or MeshCentral encryption
# keys in this file. Render those into root-owned config files from a secret
# manager instead.

# Vetted, digest-pinned images. No mutable tags such as :latest.
CADDY_IMAGE=
HEADSCALE_IMAGE=
MESHCENTRAL_IMAGE=
# The RemoteHub image is built from the checked-out source below. Pin both
# base images by digest, for example mcr.microsoft.com/dotnet/aspnet:10.0@sha256:...
REMOTEHUB_SDK_IMAGE=
REMOTEHUB_RUNTIME_IMAGE=
# A full immutable Git commit ID or signed release revision. The deployment
# guide requires it to match the checked-out RemoteHub source before building.
REMOTEHUB_SOURCE_REVISION=
# EnrollmentBroker is built independently from the same reviewed checkout. Its
# API key and journal HMAC remain file-mounted secrets, never environment vars.
ENROLLMENTBROKER_SDK_IMAGE=
ENROLLMENTBROKER_RUNTIME_IMAGE=
ENROLLMENTBROKER_SOURCE_REVISION=

# Public DNS names and ACME contact used by the rendered Caddyfile.
ACME_EMAIL=
HEADSCALE_FQDN=
MESHCENTRAL_FQDN=
REMOTEHUB_FQDN=

# Non-secret input used while rendering the Headscale template (not consumed by
# Compose directly). It must be the public IPv4 of the embedded DERP/STUN host.
HEADSCALE_PUBLIC_DERP_IPV4=

# A dedicated, non-overlapping RFC1918 /24 and fixed addresses within it.
# The rendered Headscale and MeshCentral templates must trust only
# CADDY_CONTROL_IP as their reverse proxy.
CONTROL_NETWORK_CIDR=
CADDY_CONTROL_IP=
HEADSCALE_CONTROL_IP=
MESHCENTRAL_CONTROL_IP=
REMOTEHUB_CONTROL_IP=

# Explicit host bindings. Production ACME normally requires TCP 80 and 443.
# The blank values intentionally prevent accidental public exposure.
EDGE_HTTP_BIND_ADDRESS=
EDGE_HTTP_PUBLISHED_PORT=
EDGE_HTTPS_BIND_ADDRESS=
EDGE_HTTPS_PUBLISHED_PORT=
DERP_STUN_BIND_ADDRESS=
DERP_STUN_PUBLISHED_PORT=

# Absolute, root-owned paths to rendered configuration and persistent state.
CADDYFILE=
CADDY_DATA_DIR=
CADDY_CONFIG_DIR=
HEADSCALE_CONFIG_FILE=
HEADSCALE_POLICY_FILE=
HEADSCALE_STATE_DIR=
MESHCENTRAL_CONFIG_FILE=
MESHCENTRAL_STATE_DIR=
MESHCENTRAL_FILES_DIR=
# The rendered RemoteHub configuration contains OIDC settings and the journal
# HMAC key. It is root-owned and generated outside this repository.
REMOTEHUB_CONFIG_FILE=
REMOTEHUB_JOURNAL_DIR=
# Root-owned rendered broker configuration/state and the two broker-only
# secrets. Do not place raw values in this file.
ENROLLMENTBROKER_CONFIG_FILE=
ENROLLMENTBROKER_JOURNAL_DIR=
ENROLLMENTBROKER_API_KEY_FILE=
ENROLLMENTBROKER_JOURNAL_HMAC_KEY_FILE=
